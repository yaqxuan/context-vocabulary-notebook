{
  "name": "context-vocabulary-notebook",
  "version": "0.2.0-alpha",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:e2e": "playwright test --pass-with-no-tests",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "npm run typecheck",
    "readme:i18n:check": "node scripts/verify-readme-i18n.mjs",
    "docs:links:check": "node scripts/check-doc-links.mjs",
    "smoke:install": "bash scripts/smoke-install.sh"
  },
  "dependencies": {
    "better-sqlite3": "12.10.0",
    "express": "5.2.1",
    "jszip": "3.10.1",
    "multer": "2.1.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "ts-fsrs": "5.4.1",
    "undici": "^7.26.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/express": "5.0.6",
    "@types/multer": "2.1.0",
    "@types/node": "26.1.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.0",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.5.2",
    "jsdom": "29.1.1",
    "playwright": "1.61.1",
    "postcss": "8.5.19",
    "supertest": "7.2.2",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}

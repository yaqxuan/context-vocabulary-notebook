{
  "name": "context-vocabulary-notebook",
  "version": "0.3.0-alpha.8",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.node.json && node scripts/copy-server-assets.mjs",
    "build:mobile": "vite build --config vite.mobile.config.ts",
    "android:sync": "npm run build:mobile && cap sync android",
    "android:open": "cap open android",
    "start": "node dist/server/src/server/index.js",
    "test": "vitest run",
    "test:e2e": "playwright test --pass-with-no-tests",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.mobile.json --noEmit",
    "lint": "npm run typecheck",
    "readme:i18n:check": "node scripts/verify-readme-i18n.mjs",
    "docs:links:check": "node scripts/check-doc-links.mjs",
    "smoke:install": "bash scripts/smoke-install.sh"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "better-sqlite3": "12.10.0",
    "bonjour-service": "^1.4.3",
    "express": "5.2.1",
    "jszip": "3.10.1",
    "multer": "2.2.0",
    "qrcode": "^1.5.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "selfsigned": "^5.5.0",
    "ts-fsrs": "5.4.1",
    "undici": "7.28.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/express": "5.0.6",
    "@types/multer": "2.1.0",
    "@types/node": "25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.0",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "10.5.0",
    "jsdom": "29.1.1",
    "playwright": "1.60.0",
    "postcss": "8.5.15",
    "supertest": "7.2.2",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.7"
  }
}
